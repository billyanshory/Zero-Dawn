# GambitHunter Environment Variables

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1
SANIC_ENV=production
APP_SECRET=your_super_secret_key_here
ADMIN_API_KEY=your_admin_secret_key_here

# Database
# MUST use asyncpg driver (e.g. postgresql+asyncpg://user:pass@host/db)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/gambithunter

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key
LLM_MODEL_NAME=gpt-4o-mini
# LLM_BASE_URL=

# Scraper & System Bounds
MAX_CONCURRENT_SCANS=3
BROWSER_POOL_SIZE=2
SCAN_BUDGET_SECONDS=90
LLM_TIMEOUT_SECONDS=45
LLM_MAX_INPUT_CHARS=12000
OCR_ENABLED=true
RATE_LIMIT_BACKEND=database
TRUSTED_PROXY_HEADER=X-Forwarded-For

# Proxy (Optional but Recommended)
PROXY_URL=http://proxy.example.com:8080
PROXY_USERNAME=user
PROXY_PASSWORD=pass
