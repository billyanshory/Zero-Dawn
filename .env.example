# GambitHunter Environment Variables

# (Required) PostgreSQL connection string using asyncpg driver
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/gambithunter

# (Required) LLM API configuration
LLM_API_KEY=sk-your-llm-api-key-here
LLM_MODEL_NAME=gpt-4o
# LLM_BASE_URL is optional but highly recommended if using non-OpenAI endpoints
LLM_BASE_URL=https://api.openai.com/v1

# (Required) Secure random string for Sanic sessions and cryptography (at least 64 chars)
APP_SECRET=your_super_secret_64_character_random_string_here_replace_me_in_production

# (Required) Environment: development or production
SANIC_ENV=development

# (Optional) Application binding
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1
